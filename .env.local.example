# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Upstash Redis — rate limiting for the public interview endpoints. Leave
# blank in local dev; rate limiting is skipped with a console.warn if unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Used to build links back into the admin UI from notification emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000
